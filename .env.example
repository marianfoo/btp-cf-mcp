# Config reference (copy to .env for local runs — `npm run dev` loads it if present).
# On CF these come from `cf set-env` / an mtaext + bound services, NOT this file.
# Priority: bound VCAP_SERVICES > explicit env > .env > defaults. Full details: docs/guides/admin-deployment.md
# Leave a whole group blank to disable that path. Never commit real secrets.

PORT=8080

# ─── Inbound A: IAS-first per-user OAuth ("acts as you") — the primary path ─────────────────────
# The server is its own OAuth AS, proxies login to IAS, and calls CF/BTP as the user.
# Setup recipe (IAS app, redirect URI, roles): docs/guides/per-user-ias-auth-setup.md
SEALING_SECRET=                  # REQUIRED for this path — keys the sealed MCP token JWE (openssl rand -hex 32)
# SEALING_SECRET_PREVIOUS=       # old key, only during a rotation window (unseal current + previous)
# DCR_SIGNING_SECRET=            # dedicated HMAC for OAuth DCR client_ids; set it so a SEALING_SECRET rotation doesn't force every client (Copilot Studio, VS Code…) to re-register (defaults to SEALING_SECRET)
IAS_ISSUER=                      # https://<tenant>.accounts.ondemand.com
IAS_CLIENT_ID=                   # this server's IAS OIDC app (confidential)
IAS_CLIENT_SECRET=
CF_PLATFORM_CLIENT_ID=           # the CF-platform IAS app client id (provider for the app-to-app exchange)
CF_UAA_URL=                      # https://uaa.cf.<region>.hana.ondemand.com/oauth/token
# PUBLIC_URL=                    # advertised OAuth-metadata URL when behind a proxy / for local OAuth
# MCP_REFRESH_TTL=8h             # longest before a browser re-auth (jose duration, e.g. 30d); capped by IAS's own refresh-token lifetime

# ─── Inbound B: shared read-only technical user (headless / api-key callers) ─────────────────────
# A single BTP identity for BTP-account reads via the btp CLI-server protocol (username/password login).
BTP_TECH_USER=                   # e.g. tech-user@example.com  (roles: Global Account Viewer + Subaccount Viewer)
BTP_TECH_PASSWORD=
# BTP_TECH_IDP=                  # custom IAS origin host; defaults to the IAS_ISSUER host, '' = GA default IdP

# ─── Inbound C: API keys ─────────────────────────────────────────────────────────────────────────
# Space-separated key:profile pairs. profiles: viewer | developer | admin
API_KEYS=dev-secret-123:admin
# ALLOW_OPEN=false               # dev only: true permits unauthenticated read-only access (fail-closed by default)

# ─── Outbound: BTP account (btp CLI server) ──────────────────────────────────────────────────────
BTP_GA_SUBDOMAIN=                # global-account subdomain — enables BTP-account reads (per-user AND tech-user)
BTP_DEFAULT_SUBACCOUNT=          # default subaccount GUID when no CIS key binds one

# ─── Outbound: Cloud Foundry (Cloud Controller v3) ───────────────────────────────────────────────
CF_API=https://api.cf.us10-001.hana.ondemand.com
# Shared CF backend for the api-key/headless path (per-user OAuth callers mint their own token).
# Prefer CF_REFRESH_TOKEN (durable — refreshes the ~20min access token; needs CF_UAA_URL above) over CF_TOKEN.
CF_REFRESH_TOKEN=                # from ~/.cf/config.json "RefreshToken" (strip the "bearer " prefix)
CF_TOKEN=                        # legacy static bearer (e.g. `cf oauth-token`) — dies in ~20min, superseded by the above

# ─── Outbound: BTP CIS (legacy fallback for the 3 cisFallback reads) ─────────────────────────────
# Paste a client-credentials service key (the `credentials` object or the whole key).
# Get it: btp create services/instance --offering-name cis --plan-name local --name x --parameters '{"grantType":"clientCredentials"}'
#         btp create services/binding  --instance-name x --name x-key ; btp get services/binding --name x-key
CIS_SERVICE_KEY=

# ─── Write safety ceiling (arc-1 model) — read-only by default ───────────────────────────────────
ALLOW_WRITES=false               # master mutation switch (writes are also NOT YET IMPLEMENTED — inert)
ALLOWED_SUBACCOUNTS=             # fail-closed allowlist for subaccount-targeted writes (comma-separated GUIDs)
ALLOWED_ORGS=
ALLOWED_SPACES=
DENY_ACTIONS=                    # per-action denial: Tool | Tool.action | Tool.* (validated at startup)
